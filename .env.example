# Copy to `.env` and adjust. ReFlex reads REFLEX_* variables (with `__` for nesting),
# which override values in any YAML config. Keep real secrets out of version control.

# --- LLM backend ---
# REFLEX_LLM__PROVIDER=openai
# REFLEX_LLM__MODEL=meta-llama/Llama-3.1-8B-Instruct
# REFLEX_LLM__BASE_URL=http://localhost:8000/v1
# REFLEX_LLM__API_KEY=sk-...

# --- Embeddings ---
# REFLEX_EMBEDDINGS__PROVIDER=sentence_transformers
# REFLEX_EMBEDDINGS__MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Memory ---
# REFLEX_MEMORY__DB_PATH=./data/reflex_memory.db
# REFLEX_MEMORY__RETRIEVAL__TOTAL_K=12

# --- Logging ---
# REFLEX_LOGGING__LEVEL=DEBUG
